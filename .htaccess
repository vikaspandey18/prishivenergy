# Prishiv Energy Private Limited - Server Configurations

# Disable Directory Browsing for Security
Options -Indexes

# Set Default Directory Index
DirectoryIndex index.php

# URL Rewriting for Clean SEO-friendly URLs
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 1. Redirect external requests from /filename.php to /filename
    RewriteCond %{THE_REQUEST} \s/+(.+)\.php[\s?] [NC]
    RewriteRule ^ %1 [R=301,L]

    # 2. Internal rewrite to add back .php if file exists
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^/]+)/?$ $1.php [L]
</IfModule>

# Leverage Browser Caching for Performance (SEO Friendly)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    
    # CSS and JS
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # Images and Media
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>
